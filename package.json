{
  "name": "eudi-wallet-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "EUDI Wallet Status Tracker. Open editorial record of EUDI Wallet readiness across the EU 27, EEA, UK and Switzerland. Maintained by iGrant.io.",
  "license": "EUPL-1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/L3-iGrant/eudi-wallet-tracker.git"
  },
  "homepage": "https://eudi-wallet-tracker.igrant.io",
  "bugs": {
    "url": "https://github.com/L3-iGrant/eudi-wallet-tracker/issues"
  },
  "author": {
    "name": "iGrant.io",
    "email": "support@igrant.io",
    "url": "https://www.igrant.io"
  },
  "keywords": [
    "eudi-wallet",
    "eidas",
    "digital-identity",
    "european-union",
    "tracker",
    "open-data",
    "docusaurus"
  ],
  "scripts": {
    "prestart": "node scripts/generate-country-pages.mjs && node scripts/generate-og-cards.mjs && node scripts/generate-og-default.mjs",
    "prebuild": "node scripts/generate-country-pages.mjs && node scripts/generate-og-cards.mjs && node scripts/generate-og-default.mjs",
    "start": "docusaurus start --port 2025",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --port 2025",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "validate-data": "node scripts/validate-data.mjs",
    "generate-pages": "node scripts/generate-country-pages.mjs",
    "lint:prose": "node scripts/lint-prose.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "^3.6.0",
    "@docusaurus/preset-classic": "^3.6.0",
    "@giscus/react": "^3.0.0",
    "@mdx-js/react": "^3.0.0",
    "@tanstack/react-table": "^8.20.0",
    "clsx": "^2.1.0",
    "d3-geo": "^3.1.1",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-simple-maps": "^3.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.6.0",
    "@docusaurus/tsconfig": "^3.6.0",
    "@docusaurus/types": "^3.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^18.0.0",
    "@types/react-simple-maps": "^3.0.4",
    "@types/topojson-client": "^3.1.5",
    "satori": "^0.26.0",
    "typescript": "~5.5.0"
  },
  "overrides": {
    "d3-color": "^3.1.0",
    "serialize-javascript": "^7.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
